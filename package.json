{
  "name": "kings-road",
  "private": true,
  "version": "1.5.19",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "copy:runtime-assets": "tsx scripts/copy-runtime-assets.ts",
    "copywasm": "pnpm copy:runtime-assets",
    "compile:db": "tsx scripts/compile-content-db.ts",
    "extract:glb": "tsx scripts/extract-glb-nodes.ts",
    "extract:all-packs": "tsx scripts/extract-all-packs.ts",
    "predev": "pnpm copywasm && tsx scripts/compile-content-db.ts",
    "dev": "vite",
    "prebuild": "pnpm copywasm && tsx scripts/compile-content-db.ts",
    "build": "tsc --noEmit && vite build",
    "build:native": "pnpm copywasm && tsx scripts/compile-content-db.ts && CAPACITOR=true vite build",
    "preview": "vite preview",
    "cap:sync": "pnpm copywasm && cap sync",
    "native:android:debug": "pnpm build:native && cap sync android && cd android && ./gradlew assembleDebug",
    "native:ios:build": "pnpm build:native && cap sync ios && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Debug -sdk iphonesimulator",
    "tsc": "tsc",
    "tsc-watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:browser": "pnpm copywasm && vitest run --config vitest.browser.config.ts",
    "test:browser:update": "pnpm copywasm && vitest run --config vitest.browser.config.ts --update",
    "test:e2e": "xvfb-run --auto-servernum playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "pnpm test:coverage && pnpm test:browser && pnpm test:e2e",
    "boundaries": "npx tsx scripts/check-package-boundaries.ts",
    "boundaries:update": "npx tsx scripts/check-package-boundaries.ts --update-baseline",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^7.0.0",
    "@capacitor/android": "^7.4.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/cli": "^7.4.0",
    "@capacitor/core": "^7.4.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.4.0",
    "@capacitor/preferences": "^7.0.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/three": "^0.184.0",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "koota": "^0.6.6",
    "postprocessing": "^6.39.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "simplex-noise": "^4.0.3",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "tone": "^15.1.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/code-frame": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@biomejs/biome": "2.4",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "gltfjsx": "^6.5.3",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  }
}
