{
  "name": "kings-road",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "predev": "tsx scripts/compile-content-db.ts",
    "dev": "expo start --web",
    "dev:native": "expo start",
    "install-and-dev": "pnpm install && pnpm dev",
    "build": "expo export --platform web",
    "prebuild": "tsx scripts/compile-content-db.ts",
    "tsc": "tsc",
    "tscgo": "tsgo",
    "tsc-watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "xvfb-run --auto-servernum playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:all": "pnpm test:coverage && pnpm test:ct && pnpm test:e2e",
    "compile:db": "tsx scripts/compile-content-db.ts",
    "native:start": "expo start",
    "native:ios": "expo start --ios",
    "native:android": "expo start --android"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/three": "^0.183.1",
    "@typescript/native-preview": "7.0.0-dev.20260308.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-gl": "~55.0.9",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~15.1.3",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "koota": "^0.6.5",
    "postprocessing": "^6.38.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "0.21.2",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "tone": "^15.1.22",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/code-frame": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@biomejs/biome": "2.4",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.3",
    "happy-dom": "^20.8.9",
    "jsdom": "^28.1.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
