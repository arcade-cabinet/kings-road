.expo/
expo-env.d.ts
kings-road/

pending-integration/

# Asset pack companion files — kept locally for tooling, not shipped
# Six runtime JPGs (_Color, _NormalGL, _Roughness, _Displacement, _AmbientOcclusion, _Metalness) commit
# NormalDX gitignored — WebGL uses NormalGL; shipping both is duplicate data
public/assets/pbr/**/*.blend
public/assets/pbr/**/*.blend1
public/assets/pbr/**/*.mtlx
public/assets/pbr/**/*.tres
public/assets/pbr/**/*.usdc
public/assets/pbr/**/*_NormalDX.jpg
public/assets/pbr/**/*.png
# HDRI: commit the canonical <id>.hdr alias only; ignore resolution-suffixed
# source files (e.g. *_1k.hdr, *_2k.hdr) + author companions + preview PNG.
# Loader looks up /assets/hdri/<id>/<id>.hdr; source copies would double the
# payload for no runtime benefit.
public/assets/hdri/**/*_1k.hdr
public/assets/hdri/**/*_2k.hdr
public/assets/hdri/**/*_4k.hdr
public/assets/hdri/**/*_1k.exr
public/assets/hdri/**/*_2k.exr
public/assets/hdri/**/*_4k.exr
public/assets/hdri/**/*.blend
public/assets/hdri/**/*.blend1
public/assets/hdri/**/*.png
public/assets/terrain/**/*.blend
public/assets/terrain/**/*.blend1
public/assets/terrain/**/*.png

# .remember/ is Claude's persistent memory — intentionally tracked
.remember/logs/
.remember/tmp/

# Claude Code task-batch state and compaction hook
.claude/state/
.claude/hooks/task-batch-flush.sh
.claude/worktrees/
.claude/scheduled_tasks.lock

# Playwright/DevTools MCP screenshots + snapshots (local diagnostics only)
.playwright-mcp/
kr-*.png
kr-*.jpg

# Vitest browser mode local test artifacts — CI uploads its own copy
.vitest-attachments/
app/__tests__/__screenshots__/
__screenshots__/
